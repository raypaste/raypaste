# Copy this file to .env.local and adjust values as needed.
# .env.local is git-ignored and never committed.

# Skip LLM calls during local development/testing.
# The selected text is echoed back with a "[DRY RUN]" prefix instead.
# VITE_DRY_RUN value should be "true" or "false".
VITE_DRY_RUN=false
